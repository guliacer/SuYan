{
  "name": "suyan",
  "version": "0.1.0",
  "private": false,
  "author": {
    "name": "guliacer",
    "url": "https://github.com/guliacer"
  },
  "description": "本地 AI 提示词与图像素材管理工具",
  "main": "dist-electron/electron/main/index.js",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm build && electron .",
    "start": "electron .",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "node scripts/clean-dist.cjs && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "pnpm typecheck:renderer && pnpm typecheck:electron",
    "typecheck:renderer": "tsc -p tsconfig.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "package:win": "pnpm build && node package-win.cjs",
    "protect:electron": "node scripts/obfuscate-electron.cjs dist-electron"
  },
  "dependencies": {
    "ffmpeg-static": "5.2.0",
    "jszip": "3.10.1",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.33.5",
    "uuid": "14.0.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "javascript-obfuscator": "5.4.7"
  },
  "build": {
    "appId": "local.suyan",
    "productName": "素言",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "app-integrity.json",
      "!**/*.map",
      "!**/*.md",
      "!**/LICENSE*",
      "!**/license*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "legalTrademarks": "素言 SuYan"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "素言",
      "uninstallDisplayName": "素言",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "copyright": "Copyright © 2026 素言 SuYan. All rights reserved.",
    "asar": true,
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    }
  },
  "license": "MIT",
  "homepage": "https://github.com/guliacer/SuYan",
  "bugs": {
    "url": "https://github.com/guliacer/SuYan/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guliacer/SuYan.git"
  },
  "keywords": [
    "electron",
    "react",
    "prompt",
    "ai",
    "image-library",
    "suyan"
  ]
}
